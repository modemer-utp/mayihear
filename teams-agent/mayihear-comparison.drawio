    <mxCell id="123" value="🟡 MEDIUM — Fix Graph Webhook&#xa;&#xa;• lifecycleNotificationUrl deployed ✅&#xa;• Resource URL parser deployed ✅&#xa;• Monitor logs after next meeting&#xa;• If still failing: investigate Graph&#xa;  subscription status via Graph Explorer&#xa;• No license needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;fontSize=11;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
      <mxGeometry x="1240" y="770" width="285" height="165" as="geometry" />
    </mxCell>

    <mxCell id="124" value="🟢 LOW — Acta + Durable Functions&#xa;&#xa;• Orchestrator pattern for long pipelines&#xa;• External event = user confirmation&#xa;• Survives function restarts mid-flow&#xa;• Only needed if pipeline &gt;10 min&#xa;• Significant refactor (~2-3 days)&#xa;• No extra Azure cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;fontSize=11;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
      <mxGeometry x="1565" y="770" width="285" height="165" as="geometry" />
    </mxCell>

    <mxCell id="125" value="🟢 LOW — Container Apps migration&#xa;&#xa;• Always-on (no cold starts at all)&#xa;• Better for very high polling frequency&#xa;• Cost: ~$15-30/month vs ~$0 now&#xa;• Only worth it at scale (&gt;50 users)&#xa;• Keep Functions for now" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;fontSize=11;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
      <mxGeometry x="1240" y="950" width="285" height="155" as="geometry" />
    </mxCell>

    <mxCell id="126" value="🟢 LOW — Board preference persistence&#xa;&#xa;• Currently: selected board lost on restart&#xa;• Fix: move selected_board_id/name&#xa;  from Table Storage conv state&#xa;  to dedicated user preferences blob&#xa;• Small change, ~1 hour" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;fontSize=11;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
      <mxGeometry x="1565" y="950" width="285" height="155" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════ COST BOX -->
