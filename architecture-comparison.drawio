    <!-- Pros / Cons / Resources B -->
    <mxCell id="pros_b" value="&lt;b&gt;✓ Pros&lt;/b&gt;&lt;br&gt;• Fewer services — one codebase&lt;br&gt;• Cheaper (~$13/mo, always-on B1)&lt;br&gt;• Native user interaction in Teams&lt;br&gt;• Azure ecosystem (same as M365)&lt;br&gt;• No SQS / Lambda complexity"
      style="text;html=1;align=left;fontSize=10;fontColor=#1a7a1a;verticalAlign=top;whiteSpace=wrap;"
      vertex="1" parent="1">
      <mxGeometry x="1095" y="378" width="250" height="115" as="geometry" />
    </mxCell>

    <mxCell id="cons_b" value="&lt;b&gt;✗ Cons&lt;/b&gt;&lt;br&gt;• Always-on — billed even when idle&lt;br&gt;• No built-in retries (manual logic)&lt;br&gt;• M365 Agents SDK new (Feb 2026)&lt;br&gt;• Manual horizontal scaling"
      style="text;html=1;align=left;fontSize=10;fontColor=#cc0000;verticalAlign=top;whiteSpace=wrap;"
      vertex="1" parent="1">
      <mxGeometry x="1095" y="503" width="250" height="100" as="geometry" />
