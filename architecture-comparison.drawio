    <mxCell id="r6a" value="✓ Battle-tested — AWS services GA, mayihear API already proven in production" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="225" y="906" width="770" height="32" as="geometry" /></mxCell>
