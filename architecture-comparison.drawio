    <mxCell id="r5a" value="✗ None — fully automated pipeline, no bot interaction in Teams" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="225" y="874" width="770" height="32" as="geometry" /></mxCell>
    <mxCell id="r5b" value="✓ @mayihear bot in Teams — users can query insights directly in chat" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAF0FE;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="995" y="874" width="775" height="32" as="geometry" /></mxCell>

