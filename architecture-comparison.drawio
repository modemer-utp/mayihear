    <mxCell id="r3a" value="✓ SQS automatic retries + Dead Letter Queue on failure — built-in" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="225" y="810" width="770" height="32" as="geometry" /></mxCell>
    <mxCell id="r3b" value="✗ Manual retry logic must be coded — no built-in queue or DLQ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAF0FE;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="995" y="810" width="775" height="32" as="geometry" /></mxCell>

