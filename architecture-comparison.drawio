    <!-- Pros / Cons / Resources A -->
    <mxCell id="pros_a" value="&lt;b&gt;✓ Pros&lt;/b&gt;&lt;br&gt;• Serverless — pay per use only&lt;br&gt;• SQS automatic retries + DLQ&lt;br&gt;• Auto-scales to zero when idle&lt;br&gt;• Prompt personalization by email/area&lt;br&gt;• Battle-tested AWS services"
      style="text;html=1;align=left;fontSize=10;fontColor=#1a7a1a;verticalAlign=top;whiteSpace=wrap;"
      vertex="1" parent="1">
      <mxGeometry x="1145" y="68" width="250" height="115" as="geometry" />
    </mxCell>

    <mxCell id="cons_a" value="&lt;b&gt;✗ Cons&lt;/b&gt;&lt;br&gt;• More AWS services to configure&lt;br&gt;• Higher baseline cost at low volume&lt;br&gt;• No user interaction inside Teams"
      style="text;html=1;align=left;fontSize=10;fontColor=#cc0000;verticalAlign=top;whiteSpace=wrap;"
      vertex="1" parent="1">
      <mxGeometry x="1145" y="193" width="250" height="80" as="geometry" />
    </mxCell>

    <mxCell id="res_a" value="&lt;b&gt;Resources (AWS)&lt;/b&gt;&lt;br&gt;• API Gateway&lt;br&gt;• Lambda × 2&lt;br&gt;• SQS Queue&lt;br&gt;• Secrets Manager&lt;br&gt;• mayihear API server&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size:12px;&quot;&gt;~$25–35 / month&lt;/b&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E07B00;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;"
