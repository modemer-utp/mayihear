    <mxCell id="r2a" value="✓ Auto-scale — Lambda scales to zero, no cost when idle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="225" y="778" width="770" height="32" as="geometry" /></mxCell>
    <mxCell id="r2b" value="✗ Manual — upgrade App Service tier or add instances manually" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAF0FE;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="995" y="778" width="775" height="32" as="geometry" /></mxCell>

