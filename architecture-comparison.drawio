    <mxCell id="r1a" value="~$25–35/mo  (API GW + Lambda ×2 + SQS + Secrets Manager + server)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="225" y="746" width="770" height="32" as="geometry" /></mxCell>
