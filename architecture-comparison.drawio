    <mxCell id="r4a" value="Claude / configurable — prompt personalization by user email or department area" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="225" y="842" width="770" height="32" as="geometry" /></mxCell>
    <mxCell id="r4b" value="Gemini 1.5 Flash — fast, cheap (~$0.075 / 1M input tokens)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FAF0FE;strokeColor=#cccccc;fontSize=10;" vertex="1" parent="1"><mxGeometry x="995" y="842" width="775" height="32" as="geometry" /></mxCell>

