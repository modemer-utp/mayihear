        <mxCell id="p5" value="5️⃣  Generación de Insights y Acta" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
