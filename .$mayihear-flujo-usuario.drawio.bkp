<mxfile host="app.diagrams.net" modified="2026-03-09T00:00:00.000Z" agent="Claude" version="21.0.0">
  <diagram name="Flujo MayiHear" id="mayihear-flujo">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="1">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Título -->
        <mxCell id="title" value="¿Cómo funciona MayiHear?" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry x="125" y="20" width="600" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="De la reunión al acta en Monday.com, de forma automática." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=13;fontColor=#64748b;" vertex="1" parent="1">
          <mxGeometry x="125" y="55" width="600" height="25" as="geometry" />
        </mxCell>

        <!-- PASO 1 -->
        <mxCell id="p1" value="1️⃣  Elige el proyecto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;verticalAlign=middle;arcSize=15;" vertex="1" parent="1">
          <mxGeometry x="275" y="100" width="300" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p1-desc" value="Selecciona en qué proyecto de Monday.com&lt;br&gt;se va a publicar el acta." style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#374151;" vertex="1" parent="1">
          <mxGeometry x="200" y="165" width="450" height="30" as="geometry" />
        </mxCell>

        <!-- Flecha 1→2 -->
