        <mxCell id="p2-desc" value="Presiona el botón rojo ● y MayiHear captura&lt;br&gt;el audio de la reunión en tu computadora." style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#374151;" vertex="1" parent="1">
          <mxGeometry x="200" y="275" width="450" height="30" as="geometry" />
        </mxCell>

